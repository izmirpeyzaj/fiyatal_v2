---
interface Props {
    expiresAt: string | null;
    class?: string;
}

const { expiresAt, class: className } = Astro.props;
---

{expiresAt ? (
    <div class={`countdown-container flex items-center gap-1 font-mono text-sm ${className}`} data-expires={expiresAt}>
        <span class="text-slate-500 mr-1">Kalan Süre:</span>
        <span class="days font-bold">00</span>g
        <span class="hours font-bold">00</span>s
        <span class="minutes font-bold">00</span>d
        <span class="seconds font-bold">00</span>sn
    </div>
) : (
    <div class="text-slate-400 text-sm italic">Süre Sınırı Yok</div>
)}

<script>
    function updateCountdowns() {
        const containers = document.querySelectorAll('.countdown-container');
        
        containers.forEach(container => {
            const expiryStr = container.getAttribute('data-expires');
            if (!expiryStr) return;

            const expiry = new Date(expiryStr).getTime();
            const now = new Date().getTime();
            const diff = expiry - now;

            if (diff <= 0) {
                container.innerHTML = '<span class="text-red-600 font-bold uppercase animate-pulse">SÜRE DOLDU</span>';
                return;
            }

            const days = Math.floor(diff / (1000 * 60 * 60 * 24));
            const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((diff % (1000 * 60)) / 1000);

            const dEl = container.querySelector('.days');
            const hEl = container.querySelector('.hours');
            const mEl = container.querySelector('.minutes');
            const sEl = container.querySelector('.seconds');

            if (dEl) dEl.textContent = String(days).padStart(2, '0');
            if (hEl) hEl.textContent = String(hours).padStart(2, '0');
            if (mEl) mEl.textContent = String(minutes).padStart(2, '0');
            if (sEl) sEl.textContent = String(seconds).padStart(2, '0');

            // Visual feedback for urgency
            if (diff < 24 * 60 * 60 * 1000) {
                container.classList.add('text-red-500');
                container.classList.remove('text-slate-700');
            } else {
                container.classList.add('text-slate-700');
                container.classList.remove('text-red-500');
            }
        });
    }

    setInterval(updateCountdowns, 1000);
    updateCountdowns();
</script>

<style>
    .countdown-container {
        @apply px-2 py-1 bg-slate-100 rounded-md border border-slate-200;
    }
    .text-red-500 {
        @apply bg-red-50 border-red-100;
    }
</style>
