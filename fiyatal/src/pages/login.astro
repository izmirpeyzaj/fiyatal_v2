---
import Layout from '../layouts/Layout.astro';
import { LogIn, Eye, EyeOff } from 'lucide-astro';
---

<Layout title="Giriş Yap">
	<div class="min-h-screen flex items-center justify-center p-4">
		<div class="glass-card w-full max-w-md p-8 rounded-2xl animate-in fade-in zoom-in duration-500">
			<div class="text-center mb-8">
				<h1 class="text-4xl font-extrabold text-blue-600 tracking-tight">Fiyat<span class="text-slate-900">Al</span></h1>
				<p class="text-slate-500 mt-2 font-medium">Platforma giriş yapın</p>
			</div>

			<form id="login-form" class="space-y-4">
				<div>
					<label class="block text-sm font-semibold text-slate-700 mb-1">E-posta</label>
					<input type="email" id="email" name="email" required class="input-field" placeholder="ornegin@sirket.com" />
				</div>

				<div class="relative">
					<label class="block text-sm font-semibold text-slate-700 mb-1">Şifre</label>
					<input type="password" id="password" name="password" required class="input-field" placeholder="••••••••" />
					<button type="button" id="toggle-password" class="absolute right-3 top-8 text-slate-400 hover:text-slate-600">
						<Eye size={18} id="eye-open" />
						<EyeOff size={18} id="eye-closed" class="hidden" />
					</button>
				</div>

				<div id="error-msg" class="text-red-600 text-sm font-medium hidden text-center bg-red-50 p-2 rounded-lg border border-red-100">
				</div>

				<button type="submit" id="submit-btn" class="btn-primary w-full flex items-center justify-center gap-2 h-11">
					<LogIn size={18} />
					<span>Giriş Yap</span>
				</button>
			</form>

			<div class="mt-6 text-center text-sm">
				<span class="text-slate-500">Hesabınız yok mu?</span>
				<a href="/register" class="text-blue-600 font-bold hover:underline ml-1">Kayıt Olun</a>
			</div>
		</div>
	</div>

	<script is:inline>
		const API_BASE = 'http://localhost:3001';
		const form = document.getElementById('login-form');
		const errorMsg = document.getElementById('error-msg');
		const submitBtn = document.getElementById('submit-btn');
		const passwordInput = document.getElementById('password');
		const togglePassBtn = document.getElementById('toggle-password');
		const eyeOpen = document.getElementById('eye-open');
		const eyeClosed = document.getElementById('eye-closed');

		togglePassBtn.onclick = () => {
			const isPass = passwordInput.type === 'password';
			passwordInput.type = isPass ? 'text' : 'password';
			eyeOpen.classList.toggle('hidden');
			eyeClosed.classList.toggle('hidden');
		};

		form.onsubmit = async (e) => {
			e.preventDefault();
			errorMsg.classList.add('hidden');
			submitBtn.disabled = true;
			submitBtn.innerHTML = '<span>Giriş Yapılıyor...</span>';

			const formData = new FormData(form);
			const data = Object.fromEntries(formData.entries());

			try {
				const res = await fetch(`${API_BASE}/api/auth/login`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					credentials: 'include',
					body: JSON.stringify(data)
				});

				const result = await res.json();

				if (res.ok) {
					window.location.href = `/${result.user.role}/dashboard`;
				} else {
					errorMsg.textContent = result.error;
					errorMsg.classList.remove('hidden');
				}
			} catch (err) {
				errorMsg.textContent = 'Sunucuyla bağlantı kurulamadı.';
				errorMsg.classList.remove('hidden');
			} finally {
				submitBtn.disabled = false;
				submitBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-log-in"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg><span>Giriş Yap</span>';
			}
		};
	</script>
</Layout>
