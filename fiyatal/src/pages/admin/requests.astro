---
import Layout from '../../layouts/Layout.astro';
import { Search, ShoppingBag, Folder, MessageSquare, Clock, Filter } from 'lucide-astro';
---

<Layout title="Talepleri Yönet" role="admin">
	<div class="max-w-7xl mx-auto px-4 py-8">
		<div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
			<div>
				<h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Talep Yönetimi</h1>
				<p class="text-slate-500 font-medium">Sistemdeki tüm malzeme taleplerini izleyin</p>
			</div>
			
			<div class="relative w-full md:w-80">
				<Search size={18} class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400" />
				<input type="text" id="req-search" class="input-field pl-10" placeholder="Talep ara..." />
			</div>
		</div>

		<div class="glass-card rounded-2xl overflow-hidden">
			<table class="w-full text-left text-sm">
				<thead class="bg-slate-50 text-slate-400 text-[10px] font-bold uppercase tracking-widest border-b border-slate-100">
					<tr>
						<th class="px-6 py-4">Talep Başlığı</th>
						<th class="px-6 py-4">Alıcı Şirket</th>
						<th class="px-6 py-4">Ürün Sayısı</th>
						<th class="px-6 py-4">Gelen Teklif</th>
						<th class="px-6 py-4">Tarih</th>
						<th class="px-6 py-4">Durum</th>
					</tr>
				</thead>
				<tbody id="reqs-list" class="divide-y divide-slate-50"></tbody>
			</table>
		</div>
	</div>

	<script is:inline>
		const API_BASE = 'http://localhost:3001';
		const list = document.getElementById('reqs-list');
		const search = document.getElementById('req-search');
		let allReqs = [];

		async function loadReqs() {
			try {
				const res = await fetch(`${API_BASE}/api/admin/requests`, { credentials: 'include' });
				allReqs = await res.json();
				renderReqs(allReqs);
			} catch (err) { console.error(err); }
		}

		function renderReqs(reqs) {
			list.innerHTML = reqs.map(r => `
				<tr class="hover:bg-slate-50 transition-colors">
					<td class="px-6 py-4 font-bold text-slate-900 leading-none">
						<a href="/admin/requests/${r.id}" class="hover:text-blue-600 hover:underline transition-colors">${r.title}</a>
					</td>
					<td class="px-6 py-4 font-medium text-slate-500">
						<a href="/admin/users/${r.buyer_id}" class="hover:text-blue-600 hover:underline transition-colors">${r.buyer_company}</a>
					</td>
					<td class="px-6 py-4">
						<div class="flex items-center gap-1.5 text-slate-700 font-bold">
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-folder"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/></svg>
							${r.item_count} Kalem
						</div>
					</td>
					<td class="px-6 py-4">
						<div class="flex items-center gap-1.5 text-blue-600 font-bold">
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-square"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
							${r.offer_count} Teklif
						</div>
					</td>
					<td class="px-6 py-4 text-slate-400 text-xs font-medium">
						${new Date(r.created_at).toLocaleDateString('tr-TR')}
					</td>
					<td class="px-6 py-4">
						<span class="px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-widest ${r.status === 'published' ? 'bg-green-100 text-green-700' : 'bg-slate-100 text-slate-500'}">
							${r.status === 'published' ? 'YAYINDA' : 'TASLAK'}
						</span>
					</td>
				</tr>
			`).join('');
		}

		search.oninput = () => {
			const val = search.value.toLowerCase();
			const filtered = allReqs.filter(r => 
				r.title.toLowerCase().includes(val) || 
				r.buyer_company.toLowerCase().includes(val)
			);
			renderReqs(filtered);
		};

		loadReqs();
	</script>
</Layout>
