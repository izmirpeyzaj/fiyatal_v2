---
import Layout from '../../../layouts/Layout.astro';
import { 
    User, Mail, Phone, Building2, 
    ShieldCheck, ShieldAlert, Calendar,
    Activity, ArrowUpRight, ArrowDownRight,
    Star, ChevronRight, BarChart
} from 'lucide-astro';

const { id } = Astro.params;
---

<Layout title="Kullanıcı Detayı" role="admin">
    <div class="max-w-7xl mx-auto px-4 py-8" id="user-detail" data-id={id}>
        <div class="mb-6 flex items-center gap-2 text-sm text-slate-400">
            <a href="/admin/dashboard" class="hover:text-blue-600 transition-colors">Admin</a>
            <ChevronRight size={14} />
            <span class="text-slate-600 font-medium">Kullanıcı Yönetimi</span>
            <ChevronRight size={14} />
            <span class="text-slate-600 font-medium" id="breadcrumb-user">...</span>
        </div>

        <div id="loader" class="flex flex-col items-center justify-center py-20">
            <div class="w-12 h-12 border-4 border-blue-600 border-t-transparent rounded-full animate-spin"></div>
            <p class="mt-4 text-slate-500 font-medium">Kullanıcı verileri yukleniyor...</p>
        </div>

        <div id="content" class="hidden animate-in fade-in slide-in-from-bottom-4 duration-500">
            <!-- Profile Header -->
            <div class="bg-white bg-opacity-70 backdrop-blur-md border border-slate-200 shadow-sm transition-all duration-300 p-8 rounded-3xl mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
                <div class="flex items-center gap-6">
                    <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center text-white shadow-xl shadow-blue-200">
                        <User size={40} />
                    </div>
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <h1 class="text-3xl font-black text-slate-900 tracking-tight" id="user-name">...</h1>
                            <span id="user-badge" class="px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-widest">...</span>
                        </div>
                        <p class="text-slate-500 font-medium flex items-center gap-2">
                            <span id="user-company">...</span> • <span id="user-email">...</span>
                        </p>
                    </div>
                </div>
                <div class="flex gap-3 w-full md:w-auto">
                    <button id="btn-toggle-verify" class="bg-white border border-slate-200 text-slate-700 px-5 py-2.5 rounded-xl font-bold text-sm hover:bg-slate-50 transition-all active:scale-95 flex-1 md:flex-none">...</button>
                    <button id="btn-toggle-status" class="bg-red-50 text-red-600 border border-red-100 px-5 py-2.5 rounded-xl font-bold text-sm hover:bg-red-100 transition-all active:scale-95 flex-1 md:flex-none">...</button>
                </div>
            </div>

            <!-- Stats Grid -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
                <div class="bg-white bg-opacity-70 backdrop-blur-md border border-slate-200 shadow-sm transition-all duration-300 p-6 rounded-2xl">
                    <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center mb-4">
                        <Activity size={20} />
                    </div>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Kayıt Tarihi</p>
                    <p class="text-xl font-black text-slate-900 mt-1" id="stat-created-at">...</p>
                </div>
                <div class="bg-white bg-opacity-70 backdrop-blur-md border border-slate-200 shadow-sm transition-all duration-300 p-6 rounded-2xl">
                    <div class="w-10 h-10 rounded-xl bg-green-50 text-green-600 flex items-center justify-center mb-4">
                        <BarChart size={20} />
                    </div>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest" id="stat-1-label">Aktivite</p>
                    <p class="text-xl font-black text-slate-900 mt-1" id="stat-1-value">0</p>
                </div>
                <div class="bg-white bg-opacity-70 backdrop-blur-md border border-slate-200 shadow-sm transition-all duration-300 p-6 rounded-2xl">
                    <div class="w-10 h-10 rounded-xl bg-purple-50 text-purple-600 flex items-center justify-center mb-4">
                        <ShieldCheck size={20} />
                    </div>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest" id="stat-2-label">Durum</p>
                    <p class="text-xl font-black text-slate-900 mt-1" id="stat-2-value">...</p>
                </div>
                <div class="bg-white bg-opacity-70 backdrop-blur-md border border-slate-200 shadow-sm transition-all duration-300 p-6 rounded-2xl" id="stat-rating-card">
                    <div class="w-10 h-10 rounded-xl bg-yellow-50 text-yellow-600 flex items-center justify-center mb-4">
                        <Star size={20} />
                    </div>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Puan Ortalaması</p>
                    <p class="text-xl font-black text-slate-900 mt-1" id="stat-rating">0.0</p>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Activity Feed -->
                <div class="lg:col-span-2">
                    <div class="bg-white bg-opacity-70 backdrop-blur-md border border-slate-200 shadow-sm transition-all duration-300 rounded-3xl overflow-hidden">
                        <div class="px-8 py-6 border-b border-slate-100 flex justify-between items-center">
                            <h2 class="text-xl font-bold text-slate-800">Son Aktiviteler</h2>
                            <Activity size={20} class="text-slate-300" />
                        </div>
                        <div id="activity-list" class="divide-y divide-slate-50">
                            <!-- Logs -->
                        </div>
                    </div>
                </div>

                <!-- Contact & Security -->
                <div class="space-y-6">
                    <div class="bg-white bg-opacity-70 backdrop-blur-md border border-slate-200 shadow-sm transition-all duration-300 p-6 rounded-3xl">
                        <h2 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
                            <ShieldCheck size={18} class="text-blue-600" /> İletişim Bilgileri
                        </h2>
                        <div class="space-y-4">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-lg bg-slate-50 flex items-center justify-center text-slate-400">
                                    <Mail size={16} />
                                </div>
                                <div>
                                    <p class="text-[10px] font-bold text-slate-400 uppercase">E-Posta</p>
                                    <p class="text-sm font-medium text-slate-700" id="info-email">...</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-lg bg-slate-50 flex items-center justify-center text-slate-400">
                                    <Phone size={16} />
                                </div>
                                <div>
                                    <p class="text-[10px] font-bold text-slate-400 uppercase">Telefon</p>
                                    <p class="text-sm font-medium text-slate-700" id="info-phone">...</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-lg bg-slate-50 flex items-center justify-center text-slate-400">
                                    <Building2 size={16} />
                                </div>
                                <div>
                                    <p class="text-[10px] font-bold text-slate-400 uppercase">Şirket</p>
                                    <p class="text-sm font-medium text-slate-700" id="info-company">...</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script is:inline>
        (function() {
            const API_BASE = 'http://localhost:3001';
            const userId = document.getElementById('user-detail').dataset.id;
            const loader = document.getElementById('loader');
            const content = document.getElementById('content');

            async function loadUser() {
                try {
                    const res = await fetch(`${API_BASE}/api/admin/users/${userId}`, { credentials: 'include' });
                    const data = await res.json();
                    if (data.error) throw new Error(data.error);
                    renderUser(data);
                } catch (err) {
                    loader.innerHTML = `<p class="text-red-500">Hata: ${err.message}</p>`;
                }
            }

            function renderUser(data) {
                const esc = window.escapeHtml || (s => s);
                
                document.getElementById('breadcrumb-user').textContent = data.name;
                document.getElementById('user-name').textContent = data.name;
                document.getElementById('user-company').textContent = data.company_name;
                document.getElementById('user-email').textContent = data.email;
                document.getElementById('info-email').textContent = data.email;
                document.getElementById('info-phone').textContent = data.phone || '-';
                document.getElementById('info-company').textContent = data.company_name;
                document.getElementById('stat-created-at').textContent = new Date(data.created_at).toLocaleDateString('tr-TR');

                const badge = document.getElementById('user-badge');
                badge.textContent = data.role.toUpperCase();
                badge.className = `px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-widest ${
                    data.role === 'admin' ? 'bg-red-100 text-red-600' : (data.role === 'seller' ? 'bg-blue-100 text-blue-600' : 'bg-slate-100 text-slate-600')
                }`;

                // Action Buttons Text
                const vBtn = document.getElementById('btn-toggle-verify');
                vBtn.textContent = data.is_verified ? 'Doğrulamayı Kaldır' : 'Kullanıcıyı Doğrula';
                vBtn.onclick = () => toggleVerify(data.id, !data.is_verified);

                const sBtn = document.getElementById('btn-toggle-status');
                sBtn.textContent = data.status === 'active' ? 'Kullanıcıyı Engelle' : 'Engeli Kaldır';
                sBtn.className = data.status === 'active' 
                    ? 'bg-red-50 text-red-600 border border-red-100 px-5 py-2.5 rounded-xl font-bold text-sm hover:bg-red-100 transition-all active:scale-95 flex-1 md:flex-none' 
                    : 'bg-green-50 text-green-600 border border-green-100 px-5 py-2.5 rounded-xl font-bold text-sm hover:bg-green-100 transition-all active:scale-95 flex-1 md:flex-none';
                sBtn.onclick = () => toggleStatus(data.id, data.status === 'active' ? 'blocked' : 'active');

                // Stats Logic
                if (data.role === 'buyer') {
                    document.getElementById('stat-1-label').textContent = 'Toplam Talep';
                    document.getElementById('stat-1-value').textContent = data.stats.total_requests;
                    document.getElementById('stat-2-label').textContent = 'Projeler';
                    document.getElementById('stat-2-value').textContent = data.stats.total_projects;
                    document.getElementById('stat-rating-card').classList.add('hidden');
                } else if (data.role === 'seller') {
                    document.getElementById('stat-1-label').textContent = 'Toplam Teklif';
                    document.getElementById('stat-1-value').textContent = data.stats.total_offers;
                    document.getElementById('stat-2-label').textContent = 'Onaylı Teklif';
                    document.getElementById('stat-2-value').textContent = data.stats.accepted_offers;
                    document.getElementById('stat-rating').textContent = Number(data.stats.avg_rating).toFixed(1);
                }

                // Activity Feed
                const activityRoot = document.getElementById('activity-list');
                if (data.recentActivity && data.recentActivity.length > 0) {
                    activityRoot.innerHTML = data.recentActivity.map(log => `
                        <div class="px-8 py-4 flex items-start gap-4 hover:bg-slate-50/50 transition-colors">
                            <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 mt-1">
                                <Activity size={14} />
                            </div>
                            <div>
                                <p class="text-sm font-bold text-slate-900">${esc(log.action.replace(/_/g, ' ').toUpperCase())}</p>
                                <p class="text-xs text-slate-500">${esc(log.details || 'Detay belirtilmemiş.')}</p>
                                <p class="text-[10px] text-slate-400 mt-1">${new Date(log.created_at).toLocaleString('tr-TR')}</p>
                            </div>
                        </div>
                    `).join('');
                } else {
                    activityRoot.innerHTML = '<div class="text-center py-10 text-slate-400 italic text-sm">Aktivite kaydı bulunamadı.</div>';
                }

                loader.classList.add('hidden');
                content.classList.remove('hidden');
            }

            async function toggleVerify(id, val) {
                if (!confirm('Kullanıcı doğrulama durumunu değiştirmek istiyor musunuz?')) return;
                await fetch(`${API_BASE}/api/admin/users/${id}/verify`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ is_verified: val })
                });
                loadUser();
            }

            async function toggleStatus(id, stat) {
                if (!confirm('Kullanıcı durumunu değiştirmek istiyor musunuz?')) return;
                await fetch(`${API_BASE}/api/admin/users/${id}/status`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ status: stat })
                });
                loadUser();
            }

            loadUser();
        })();
    </script>
</Layout>

<!-- Styles moved to utility classes -->
