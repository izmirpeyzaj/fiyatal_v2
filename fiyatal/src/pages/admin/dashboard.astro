---
import Layout from '../../layouts/Layout.astro';
import { Users, ShoppingBag, MessageSquare, TrendingUp, ChevronRight, AlertCircle } from 'lucide-astro';
---

<Layout title="Yönetici Paneli" role="admin">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
		<div class="mb-8">
			<h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">System Dashboard</h1>
			<p class="text-slate-500 font-medium">Platform genelindeki anlık veriler ve istatistikler</p>
		</div>

		<!-- Stats Grid -->
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
			{[
				{ label: 'Toplam Alıcı', id: 'total-buyers', icon: Users, color: 'blue' },
				{ label: 'Toplam Satıcı', id: 'total-sellers', icon: ShoppingBag, color: 'green' },
				{ label: 'Aktif Talepler', id: 'active-requests', icon: AlertCircle, color: 'orange' },
				{ label: 'Toplam Teklif', id: 'total-offers', icon: MessageSquare, color: 'purple' }
			].map(stat => (
				<div class="glass-card p-6 rounded-2xl border-l-4 border-l-blue-500">
					<div class="flex items-center gap-4">
						<div class={`p-3 rounded-xl bg-${stat.color}-50 text-${stat.color}-600`}>
							<stat.icon size={24} />
						</div>
						<div>
							<p class="text-xs font-bold text-slate-400 uppercase tracking-widest">{stat.label}</p>
							<p id={stat.id} class="text-2xl font-black text-slate-900">...</p>
						</div>
					</div>
				</div>
			))}
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
			<!-- Recent Requests -->
			<div class="glass-card rounded-2xl overflow-hidden">
				<div class="p-6 border-b border-slate-100 flex justify-between items-center">
					<h2 class="font-bold text-slate-900 flex items-center gap-2">
						<TrendingUp size={20} class="text-blue-600" />
						Son Talepler
					</h2>
					<a href="/admin/requests" class="text-xs font-bold text-blue-600 hover:underline">Tümünü Gör</a>
				</div>
				<div class="overflow-x-auto">
					<table class="w-full text-left text-sm">
						<thead class="bg-slate-50 text-slate-400 text-[10px] font-bold uppercase">
							<tr>
								<th class="px-6 py-3">Başlık</th>
								<th class="px-6 py-3">Alıcı</th>
								<th class="px-6 py-3">Teklif</th>
								<th class="px-6 py-3">Tarih</th>
							</tr>
						</thead>
						<tbody id="recent-requests" class="divide-y divide-slate-50"></tbody>
					</table>
				</div>
			</div>

			<!-- Quick Actions / Export -->
			<div class="glass-card rounded-2xl p-6">
				<h2 class="font-bold text-slate-900 mb-6 flex items-center gap-2">
					<AlertCircle size={20} class="text-blue-600" />
					Hızlı İşlemler & Raporlar
				</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
					<a href="/admin/export" class="flex items-center justify-between p-4 rounded-xl border border-slate-100 bg-slate-50 hover:bg-white hover:shadow-lg transition-all group">
						<div class="flex items-center gap-3">
							<div class="p-2 bg-blue-100 text-blue-600 rounded-lg">
								<ShoppingBag size={20} />
							</div>
							<div>
								<p class="text-sm font-bold text-slate-900">Excel Export</p>
								<p class="text-[10px] text-slate-400 font-medium tracking-tight">Tüm veri setini indir</p>
							</div>
						</div>
						<ChevronRight size={16} class="text-slate-300 group-hover:text-blue-600 transition-colors" />
					</a>
					<a href="/admin/buyers" class="flex items-center justify-between p-4 rounded-xl border border-slate-100 bg-slate-50 hover:bg-white hover:shadow-lg transition-all group">
						<div class="flex items-center gap-3">
							<div class="p-2 bg-green-100 text-green-600 rounded-lg">
								<Users size={20} />
							</div>
							<div>
								<p class="text-sm font-bold text-slate-900">Alıcı Yönetimi</p>
								<p class="text-[10px] text-slate-400 font-medium tracking-tight">Kullanıcıları blokla / aç</p>
							</div>
						</div>
						<ChevronRight size={16} class="text-slate-300 group-hover:text-green-600 transition-colors" />
					</a>
				</div>
			</div>
		</div>
	</div>

	<script is:inline>
		async function loadStats() {
			try {
				const res = await fetch('http://localhost:3001/api/admin/stats', { credentials: 'include' });
				const stats = await res.json();
				document.getElementById('total-buyers').textContent = stats.total_buyers;
				document.getElementById('total-sellers').textContent = stats.total_sellers;
				document.getElementById('active-requests').textContent = stats.active_requests;
				document.getElementById('total-offers').textContent = stats.total_offers;
			} catch (err) { console.error(err); }
		}

		async function loadRecent() {
			try {
				const res = await fetch('http://localhost:3001/api/admin/requests', { credentials: 'include' });
				const reqs = await res.json();
				const container = document.getElementById('recent-requests');
				container.innerHTML = reqs.slice(0, 5).map(req => `
					<tr class="hover:bg-slate-50 transition-colors">
						<td class="px-6 py-4 font-bold text-slate-900">${req.title}</td>
						<td class="px-6 py-4 text-slate-500">${req.buyer_company}</td>
						<td class="px-6 py-4">
							<span class="bg-blue-100 text-blue-600 text-xs font-bold px-2 py-0.5 rounded-full">${req.offer_count} Teklif</span>
						</td>
						<td class="px-6 py-4 text-slate-400 text-xs">${new Date(req.created_at).toLocaleDateString('tr-TR')}</td>
					</tr>
				`).join('');
			} catch (err) { console.error(err); }
		}

		loadStats();
		loadRecent();
	</script>
</Layout>
