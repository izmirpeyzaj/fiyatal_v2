---
import Layout from '../../layouts/Layout.astro';
import { Users, ShoppingBag, MessageSquare, TrendingUp, ChevronRight, AlertCircle } from 'lucide-astro';
---

<Layout title="Yönetici Paneli" role="admin">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
		<div class="mb-8">
			<h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">System Dashboard</h1>
			<p class="text-slate-500 font-medium">Platform genelindeki anlık veriler ve istatistikler</p>
		</div>

		<!-- Stats Grid -->
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
			{[
				{ label: 'Toplam Alıcı', id: 'total-buyers', icon: Users, color: 'blue' },
				{ label: 'Toplam Satıcı', id: 'total-sellers', icon: ShoppingBag, color: 'green' },
				{ label: 'Aktif Talepler', id: 'active-requests', icon: AlertCircle, color: 'orange' },
				{ label: 'Toplam Teklif', id: 'total-offers', icon: MessageSquare, color: 'purple' }
			].map(stat => (
				<div class="glass-card p-6 rounded-2xl border-l-4 border-l-blue-500">
					<div class="flex items-center gap-4">
						<div class={`p-3 rounded-xl bg-${stat.color}-50 text-${stat.color}-600`}>
							<stat.icon size={24} />
						</div>
						<div>
							<p class="text-xs font-bold text-slate-400 uppercase tracking-widest">{stat.label}</p>
							<p id={stat.id} class="text-2xl font-black text-slate-900">...</p>
						</div>
					</div>
				</div>
			))}
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
			<div class="glass-card rounded-2xl overflow-hidden lg:col-span-2">
				<div class="p-6 border-b border-slate-100 flex justify-between items-center">
					<h2 class="font-bold text-slate-900 flex items-center gap-2">
						<TrendingUp size={20} class="text-blue-600" />
						Son Talepler
					</h2>
					<a href="/admin/requests" class="text-xs font-bold text-blue-600 hover:underline">Tumunu Gor</a>
				</div>
				<div class="overflow-x-auto">
					<table class="w-full text-left text-sm">
						<thead class="bg-slate-50 text-slate-400 text-[10px] font-bold uppercase">
							<tr>
								<th class="px-6 py-3">Baslik</th>
								<th class="px-6 py-3">Alici</th>
								<th class="px-6 py-3">Teklif</th>
								<th class="px-6 py-3">Tarih</th>
							</tr>
						</thead>
						<tbody id="recent-requests" class="divide-y divide-slate-50"></tbody>
					</table>
				</div>
			</div>

			<div class="glass-card rounded-2xl p-6">
				<h2 class="font-bold text-slate-900 mb-6 flex items-center gap-2">
					<AlertCircle size={20} class="text-blue-600" />
					Hizli Islemler
				</h2>
				<div class="space-y-3">
					<a href="/admin/export" class="flex items-center justify-between p-4 rounded-xl border border-slate-100 bg-slate-50 hover:bg-white hover:shadow-lg transition-all group">
						<div class="flex items-center gap-3">
							<div class="p-2 bg-blue-100 text-blue-600 rounded-lg"><ShoppingBag size={18} /></div>
							<div>
								<p class="text-sm font-bold text-slate-900">Excel Export</p>
								<p class="text-[10px] text-slate-400">Tum veri setini indir</p>
							</div>
						</div>
						<ChevronRight size={16} class="text-slate-300 group-hover:text-blue-600 transition-colors" />
					</a>
					<a href="/admin/buyers" class="flex items-center justify-between p-4 rounded-xl border border-slate-100 bg-slate-50 hover:bg-white hover:shadow-lg transition-all group">
						<div class="flex items-center gap-3">
							<div class="p-2 bg-green-100 text-green-600 rounded-lg"><Users size={18} /></div>
							<div>
								<p class="text-sm font-bold text-slate-900">Alici Yonetimi</p>
								<p class="text-[10px] text-slate-400">Kullanicilari blokla / ac</p>
							</div>
						</div>
						<ChevronRight size={16} class="text-slate-300 group-hover:text-green-600 transition-colors" />
					</a>
					<a href="/admin/sellers" class="flex items-center justify-between p-4 rounded-xl border border-slate-100 bg-slate-50 hover:bg-white hover:shadow-lg transition-all group">
						<div class="flex items-center gap-3">
							<div class="p-2 bg-orange-100 text-orange-600 rounded-lg"><Users size={18} /></div>
							<div>
								<p class="text-sm font-bold text-slate-900">Satici Yonetimi</p>
								<p class="text-[10px] text-slate-400">Satici hesaplarini yonet</p>
							</div>
						</div>
						<ChevronRight size={16} class="text-slate-300 group-hover:text-orange-600 transition-colors" />
					</a>
				</div>
			</div>
		</div>

		<div class="glass-card rounded-2xl p-6">
			<h2 class="font-bold text-slate-900 mb-6 flex items-center gap-2">
				<TrendingUp size={20} class="text-blue-600" />
				Aylik Aktivite
			</h2>
			<div id="monthly-chart" class="flex items-end gap-2 h-40"></div>
			<div id="monthly-labels" class="flex gap-2 mt-2"></div>
		</div>
	</div>

	<script is:inline>
		const API_BASE = 'http://localhost:3001';
		async function loadStats() {
			try {
				const res = await fetch(`${API_BASE}/api/admin/stats`, { credentials: 'include' });
				const stats = await res.json();
				document.getElementById('total-buyers').textContent = stats.total_buyers;
				document.getElementById('total-sellers').textContent = stats.total_sellers;
				document.getElementById('active-requests').textContent = stats.active_requests;
				document.getElementById('total-offers').textContent = stats.total_offers;
			} catch (err) { console.error(err); }
		}

		async function loadRecent() {
			try {
				const res = await fetch(`${API_BASE}/api/admin/requests`, { credentials: 'include' });
				const reqs = await res.json();
				const container = document.getElementById('recent-requests');
				container.innerHTML = reqs.slice(0, 5).map(req => `
					<tr class="hover:bg-slate-50 transition-colors">
						<td class="px-6 py-4 font-bold text-slate-900">${req.title}</td>
						<td class="px-6 py-4 text-slate-500">${req.buyer_company}</td>
						<td class="px-6 py-4">
							<span class="bg-blue-100 text-blue-600 text-xs font-bold px-2 py-0.5 rounded-full">${req.offer_count} Teklif</span>
						</td>
						<td class="px-6 py-4 text-slate-400 text-xs">${new Date(req.created_at).toLocaleDateString('tr-TR')}</td>
					</tr>
				`).join('');
			} catch (err) { console.error(err); }
		}

		async function loadMonthly() {
			try {
				const res = await fetch(`${API_BASE}/api/admin/stats/detailed`, { credentials: 'include' });
				const data = await res.json();
				const chart = document.getElementById('monthly-chart');
				const labels = document.getElementById('monthly-labels');
				if (!data.monthlyData || data.monthlyData.length === 0) {
					chart.innerHTML = '<p class="text-slate-400 text-sm w-full text-center">Henuz veri yok.</p>';
					return;
				}
				const max = Math.max(...data.monthlyData.map(m => m.requests || 0), 1);
				chart.innerHTML = data.monthlyData.map(m => {
					const h = Math.max(((m.requests || 0) / max) * 100, 4);
					return '<div class="flex-1 flex flex-col items-center gap-1"><span class="text-[10px] font-bold text-slate-500">' + (m.requests || 0) + '</span><div class="chart-bar w-full" style="height:' + h + '%"></div></div>';
				}).join('');
				labels.innerHTML = data.monthlyData.map(m => '<div class="flex-1 text-center text-[10px] text-slate-400 font-medium">' + (m.month || '').slice(5) + '</div>').join('');
			} catch (e) {}
		}

		loadStats();
		loadRecent();
		loadMonthly();
	</script>
</Layout>
