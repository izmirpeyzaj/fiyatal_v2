---
import Layout from '../../../layouts/Layout.astro';
import { ChevronLeft, Info, MapPin, List, CheckCircle2 } from 'lucide-astro';

const { id } = Astro.params;
---

<Layout title="Talep Detayı" role="seller">
	<div class="max-w-xl mx-auto px-4 py-8 pb-24">
		<a href="/seller/dashboard" class="flex items-center gap-1 text-slate-500 font-bold mb-6 hover:text-blue-600 transition-colors">
			<ChevronLeft size={20} /> Geri Dön
		</a>

		<div id="loading" class="animate-pulse space-y-4">
			<div class="h-8 bg-slate-200 rounded w-3/4"></div>
			<div class="h-32 bg-slate-200 rounded-2xl"></div>
		</div>

		<div id="content" class="hidden space-y-6">
			<div>
				<h1 id="req-title" class="text-2xl font-extrabold text-slate-900 tracking-tight mb-2"></h1>
				<div class="flex items-center gap-2">
					<span id="buyer-company" class="bg-blue-100 text-blue-700 text-xs font-bold px-2 py-1 rounded"></span>
					<span id="created-at" class="text-slate-400 text-xs font-medium"></span>
				</div>
			</div>

			<div class="glass-card p-6 rounded-3xl space-y-4">
				<div class="flex items-start gap-4">
					<div class="p-2 bg-slate-100 rounded-xl">
						<MapPin size={24} class="text-slate-600" />
					</div>
					<div>
						<p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mb-1">Teslimat Adresi</p>
						<p id="delivery-address" class="text-sm font-medium text-slate-700"></p>
						<div id="map-preview" class="h-32 w-full mt-2 rounded-xl border border-slate-100 overflow-hidden"></div>
					</div>
				</div>

				</div>

				<!-- Attachments Section -->
				<div id="attachments-section" class="hidden flex items-start gap-4">
					<div class="p-2 bg-slate-100 rounded-xl">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-600"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.51a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
					</div>
					<div class="flex-grow">
						<p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mb-1">Teknik Dokümanlar</p>
						<div id="attachments-container" class="flex flex-wrap gap-2 pt-1"></div>
					</div>
				</div>
			</div>

			<div class="space-y-3">
				<div class="flex items-center gap-2 px-2 text-slate-900 font-bold">
					<List size={18} /> Ürün Listesi (<span id="item-count">0</span>)
				</div>
				<div id="item-list" class="space-y-2"></div>
			</div>

			<div class="pt-6">
				<a id="start-quote-btn" class="btn-primary w-full h-14 flex items-center justify-center gap-2 text-lg font-bold rounded-2xl shadow-xl shadow-blue-500/20">
					Fiyat Vermeye Başla <CheckCircle2 size={24} />
				</a>
			</div>
		</div>
	</div>

	<script is:inline src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

	<script is:inline>
		const API_BASE = 'http://localhost:3001';
		const id = window.location.pathname.split('/').pop();
		const loading = document.getElementById('loading');
		const content = document.getElementById('content');

		async function loadDetail() {
			try {
				const res = await fetch(`${API_BASE}/api/seller/requests/${id}`, { credentials: 'include' });
				const req = await res.json();

				document.getElementById('req-title').textContent = req.title;
				document.getElementById('buyer-company').textContent = req.buyer_company;
				document.getElementById('created-at').textContent = new Date(req.created_at).toLocaleDateString('tr-TR');
				document.getElementById('delivery-address').textContent = req.delivery_address || 'Adres belirtilmemiş';
				document.getElementById('item-count').textContent = req.items.length;
				document.getElementById('start-quote-btn').href = `/seller/quote/${id}`;

				const badgesContainer = document.getElementById('req-badges');
				if (req.photo_required) badgesContainer.innerHTML += '<span class="px-2 py-0.5 bg-orange-100 text-orange-600 rounded-full text-[10px] font-bold">📷 FOTOĞRAF ZORUNLU</span>';
				if (req.location_required) badgesContainer.innerHTML += '<span class="px-2 py-0.5 bg-sky-100 text-sky-600 rounded-full text-[10px] font-bold">📍 KONUM ZORUNLU</span>';
				badgesContainer.innerHTML += `<span class="px-2 py-0.5 bg-slate-100 text-slate-600 rounded-full text-[10px] font-bold">🚚 NAKLİYE: ${req.shipping_note.toUpperCase()}</span>`;

				const attachmentsSection = document.getElementById('attachments-section');
				const attachmentsContainer = document.getElementById('attachments-container');
				if (req.attachments && req.attachments.length > 0) {
					attachmentsSection.classList.remove('hidden');
					attachmentsContainer.innerHTML = req.attachments.map(asset => `
						<a href="${asset.type === 'file' ? API_BASE + asset.url : asset.url}" target="_blank" class="flex items-center gap-2 px-3 py-1 bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-full text-[10px] font-bold border border-slate-200 transition-colors">
							${asset.type === 'file' ? '📄' : '🔗'} ${asset.name}
						</a>
					`).join('');
				}

				const list = document.getElementById('item-list');
				list.innerHTML = req.items.map(item => {
					const properties = item.properties || {};
					
					const normalize = (str) => {
						if (!str) return '';
						return str.toLowerCase()
							.replace(/ı/g, 'i')
							.replace(/ğ/g, 'g')
							.replace(/ü/g, 'u')
							.replace(/ş/g, 's')
							.replace(/ö/g, 'o')
							.replace(/ç/g, 'c')
							.replace(/i̇/g, 'i')
							.trim();
					};

					const findVal = (keys) => {
						const entries = Object.entries(properties);
						for (const [k, v] of entries) {
							const normalizedK = normalize(k);
							if (keys.some(key => normalizedK.includes(normalize(key)))) {
								return v;
							}
						}
						return null;
					};

					const mainText = findVal(['açıklama', 'tanım', 'is', 'urun', 'item']) || 'İsimsiz Ürün';
					const qty = findVal(['miktar', 'adet', 'sayi', 'qty']) || '-';
					const unit = findVal(['birim', 'olcu', 'unit']) || '-';
					
					const otherProps = Object.entries(properties)
						.filter(([k]) => !['açıklama', 'tanım', 'is', 'urun', 'item', 'miktar', 'adet', 'sayi', 'qty', 'birim', 'olcu', 'unit'].some(key => normalize(k).includes(normalize(key))))
						.map(([k, v]) => `<span class="bg-slate-50 px-2 py-0.5 rounded border border-slate-100">${k}: ${v}</span>`)
						.join(' ');

					return `
						<div class="bg-white border border-slate-100 p-4 rounded-2xl flex items-center gap-4 hover:border-blue-200 transition-colors group">
							<div class="w-10 h-10 rounded-xl bg-slate-900 text-white flex items-center justify-center text-sm font-black shadow-lg shadow-slate-900/10">
								${item.item_order}
							</div>
							<div class="flex-grow">
								<p class="text-base font-black text-slate-900 leading-tight">${mainText}</p>
								<div class="flex flex-wrap items-center gap-3 mt-2">
									<span class="text-[10px] font-black text-blue-600 bg-blue-50 px-2 py-0.5 rounded uppercase tracking-widest">
										MİKTAR: ${qty} ${unit}
									</span>
									<div class="text-[9px] text-slate-400 font-bold flex flex-wrap gap-2">
										${otherProps}
									</div>
								</div>
							</div>
						</div>
					`;
				}).join('');

				loading.classList.add('hidden');
				content.classList.remove('hidden');

				if (req.delivery_lat) {
					setTimeout(() => {
						const map = L.map('map-preview', { zoomControl: false, attributionControl: false }).setView([req.delivery_lat, req.delivery_lng], 13);
						L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
						L.marker([req.delivery_lat, req.delivery_lng]).addTo(map);
						map.dragging.disable();
						map.touchZoom.disable();
						map.doubleClickZoom.disable();
						map.scrollWheelZoom.disable();
					}, 100);
				}
			} catch (err) {
				console.error(err);
			}
		}

		loadDetail();
	</script>
</Layout>
