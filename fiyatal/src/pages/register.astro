---
import Layout from '../layouts/Layout.astro';
import { UserPlus, Building2, ShoppingBag } from 'lucide-astro';
---

<Layout title="Kayıt Ol">
	<div class="min-h-screen flex items-center justify-center p-4">
		<div class="glass-card w-full max-w-lg p-8 rounded-2xl animate-in fade-in slide-in-from-bottom-4 duration-500">
			<div class="text-center mb-6">
				<h1 class="text-3xl font-extrabold text-blue-600 tracking-tight">Hesap Oluştur</h1>
				<p class="text-slate-500 mt-1 font-medium">Size en uygun hesap türünü seçerek başlayın</p>
			</div>

			<!-- Role Selection -->
			<div class="grid grid-cols-2 gap-4 mb-8" id="role-selector">
				<button type="button" data-role="buyer" class="role-btn group flex flex-col items-center gap-3 p-4 rounded-xl border-2 border-slate-100 hover:border-blue-200 hover:bg-blue-50/50 transition-all text-slate-600">
					<div class="w-12 h-12 rounded-full bg-slate-100 group-hover:bg-blue-100 flex items-center justify-center transition-colors">
						<ShoppingBag size={24} class="group-hover:text-blue-600" />
					</div>
					<span class="font-bold">Alıcıyım</span>
				</button>
				<button type="button" data-role="seller" class="role-btn group flex flex-col items-center gap-3 p-4 rounded-xl border-2 border-slate-100 hover:border-blue-200 hover:bg-slate-50 transition-all text-slate-600">
					<div class="w-12 h-12 rounded-full bg-slate-100 group-hover:bg-green-100 flex items-center justify-center transition-colors">
						<Building2 size={24} class="group-hover:text-green-600" />
					</div>
					<span class="font-bold">Satıcıyım</span>
				</button>
			</div>

			<form id="register-form" class="space-y-4 hidden">
				<input type="hidden" name="role" id="selected-role" />
				
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
					<div>
						<label class="block text-sm font-semibold text-slate-700 mb-1">Ad Soyad</label>
						<input type="text" name="name" required class="input-field" placeholder="Ad Soyad" />
					</div>
					<div>
						<label class="block text-sm font-semibold text-slate-700 mb-1">Şirket Adı</label>
						<input type="text" name="company_name" required class="input-field" placeholder="Şirketiniz" />
					</div>
				</div>

				<div>
					<label class="block text-sm font-semibold text-slate-700 mb-1">E-posta</label>
					<input type="email" name="email" required class="input-field" placeholder="ornegin@sirket.com" />
				</div>

				<div>
					<label class="block text-sm font-semibold text-slate-700 mb-1">Telefon</label>
					<input type="tel" name="phone" required class="input-field" placeholder="05XX XXX XX XX" />
				</div>

				<div>
					<label class="block text-sm font-semibold text-slate-700 mb-1">Şifre</label>
					<input type="password" name="password" required class="input-field" placeholder="••••••••" />
				</div>

				<div id="error-msg" class="text-red-600 text-sm font-medium hidden text-center bg-red-50 p-2 rounded-lg border border-red-100">
				</div>

				<button type="submit" id="submit-btn" class="btn-primary w-full flex items-center justify-center gap-2 h-11">
					<UserPlus size={18} />
					<span>Kayıt Ol</span>
				</button>
			</form>

			<div class="mt-6 text-center text-sm">
				<span class="text-slate-500">Zaten hesabınız var mı?</span>
				<a href="/login" class="text-blue-600 font-bold hover:underline ml-1">Giriş Yapın</a>
			</div>
		</div>
	</div>

	<script is:inline>
		const roleBtns = document.querySelectorAll('.role-btn');
		const roleInput = document.getElementById('selected-role');
		const form = document.getElementById('register-form');
		const errorMsg = document.getElementById('error-msg');
		const submitBtn = document.getElementById('submit-btn');

		roleBtns.forEach(btn => {
			btn.onclick = () => {
				const role = btn.dataset.role;
				roleInput.value = role;
				
				// Update UI
				roleBtns.forEach(b => {
					b.classList.remove('border-blue-600', 'bg-blue-50', 'ring-2', 'ring-blue-100');
					b.classList.add('border-slate-100');
				});
				btn.classList.add('border-blue-600', 'bg-blue-50', 'ring-2', 'ring-blue-100');
				btn.classList.remove('border-slate-100');

				form.classList.remove('hidden');
				form.scrollIntoView({ behavior: 'smooth' });
			};
		});

		form.onsubmit = async (e) => {
			e.preventDefault();
			errorMsg.classList.add('hidden');
			submitBtn.disabled = true;
			submitBtn.textContent = 'Kaydediliyor...';

			const formData = new FormData(form);
			const data = Object.fromEntries(formData.entries());

			try {
				const res = await fetch('http://localhost:3001/api/auth/register', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					credentials: 'include',
					body: JSON.stringify(data)
				});

				const result = await res.json();

				if (res.ok) {
					alert('Kayıt başarılı! Giriş yapabilirsiniz.');
					window.location.href = '/login';
				} else {
					errorMsg.textContent = result.error;
					errorMsg.classList.remove('hidden');
				}
			} catch (err) {
				errorMsg.textContent = 'Sunucuyla bağlantı kurulamadı.';
				errorMsg.classList.remove('hidden');
			} finally {
				submitBtn.disabled = false;
				submitBtn.textContent = 'Kayıt Ol';
			}
		};
	</script>
</Layout>
