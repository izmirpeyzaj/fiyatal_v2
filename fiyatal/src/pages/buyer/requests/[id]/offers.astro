---
import Layout from '../../../../layouts/Layout.astro';
import { ChevronLeft, Info, MapPin, Camera, User, Phone, PhoneCall } from 'lucide-astro';

const { id } = Astro.params;
---

<Layout title="Gelen Teklifler" role="buyer">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
		<a href="/buyer/dashboard" class="flex items-center gap-1 text-slate-500 font-bold mb-6 hover:text-blue-600 transition-colors">
			<ChevronLeft size={20} /> Taleplerime Dön
		</a>

		<div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
			<div>
				<h1 id="req-title" class="text-3xl font-extrabold text-slate-900 tracking-tight">Gelen Teklifler</h1>
				<div class="flex items-center gap-3 mt-1">
					<p id="req-stats" class="text-slate-500 font-medium"></p>
					<a id="btn-compare" href="#" class="hidden px-4 py-1.5 bg-blue-600 text-white text-[11px] font-black rounded-full hover:bg-slate-900 transition-all shadow-lg shadow-blue-600/20 uppercase tracking-widest">KARŞILAŞTIRMA MATRİSİ</a>
				</div>
			</div>

			<div class="glass-card p-4 rounded-2xl flex flex-col md:flex-row items-center gap-3">
				<div class="text-left w-full md:w-auto">
					<p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Başka birinden teklif mi istiyorsunuz?</p>
					<p class="text-[11px] text-slate-500 font-medium">Email girerek sistemi kullanmaya davet edin.</p>
				</div>
				<div class="flex gap-2 w-full md:w-auto">
					<input type="email" id="invite-email" class="input-field h-10 w-full md:w-48 text-sm" placeholder="ornek@mail.com" />
					<button id="btn-invite" class="btn-primary h-10 px-4 text-xs font-bold whitespace-nowrap">Davet Et</button>
				</div>
			</div>
		</div>

		<div class="glass-card rounded-2xl overflow-hidden">
			<table class="w-full text-left text-sm">
				<thead class="bg-slate-50 text-slate-400 text-[10px] font-bold uppercase tracking-widest border-b border-slate-100">
					<tr>
						<th class="px-6 py-4">Satıcı & Şirket</th>
						<th class="px-6 py-4">Tarih</th>
						<th class="px-6 py-4">Nakliye</th>
						<th class="px-6 py-4">Ekler</th>
						<th class="px-6 py-4">Toplam Tutar</th>
						<th class="px-6 py-4 text-right">İşlem</th>
					</tr>
				</thead>
				<tbody id="offers-list" class="divide-y divide-slate-50">
					<!-- Loading -->
					<tr>
						<td colspan="6" class="px-6 py-20 text-center animate-pulse text-slate-400 font-medium">Teklifler Yükleniyor...</td>
					</tr>
				</tbody>
			</table>
		</div>

		<div id="empty-state" class="hidden flex flex-col items-center justify-center py-20 text-center">
			<div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center mb-4">
				<Info size={40} class="text-slate-300" />
			</div>
			<h3 class="text-xl font-bold text-slate-900">Henüz teklif gelmedi</h3>
			<p class="text-slate-500 mt-2">Satıcılar teklif verdiğinde burada listelenecektir.</p>
		</div>

		<!-- Q&A Section -->
		<div class="mt-16 pt-8 border-t border-slate-200">
			<div class="flex items-center gap-3 mb-6">
				<div class="p-2 bg-purple-100 text-purple-600 rounded-xl">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-square-quote"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/></svg>
				</div>
				<div>
					<h2 class="text-2xl font-black text-slate-900 leading-tight">Soru & Cevap</h2>
					<p class="text-sm text-slate-500 font-medium">Satıcılar tarafından sorulan kalem teknik soruları</p>
				</div>
			</div>

			<div id="questions-list" class="space-y-4">
				<div class="animate-pulse text-slate-400 font-medium text-center py-10">Sorular Yükleniyor...</div>
			</div>
		</div>
	</div>

	<!-- Answer Modal -->
	<div id="answer-modal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
		<div class="glass-card w-full max-w-md p-8 rounded-3xl shadow-2xl animate-in zoom-in-95 duration-200">
			<h3 class="text-2xl font-black text-slate-900 mb-2">Soruyu Yanıtla</h3>
			<p id="modal-question-text" class="text-slate-600 mb-6 italic italic"></p>
			<textarea id="answer-text" class="input-field min-h-[120px] mb-6 p-4" placeholder="Yanıtınızı buraya yazın..."></textarea>
			<div class="flex gap-3">
				<button id="close-answer-modal" class="btn-secondary flex-1">Vazgeç</button>
				<button id="submit-answer" class="btn-primary flex-1">Yanıtla</button>
			</div>
		</div>
	</div>
	</div>

	<script is:inline>
		const id = window.location.pathname.split('/')[3];
		const list = document.getElementById('offers-list');
		const emptyState = document.getElementById('empty-state');

		async function loadOffers() {
			try {
				const res = await fetch(`http://localhost:3001/api/buyer/requests/${id}/offers`, { credentials: 'include' });
				const offers = await res.json();

				if (offers.length === 0) {
					list.parentElement.parentElement.classList.add('hidden');
					emptyState.classList.remove('hidden');
					return;
				}

				document.getElementById('req-stats').textContent = `${offers.length} Satıcıdan teklif alındı`;
				if (offers.length > 1) {
					const compareBtn = document.getElementById('btn-compare');
					compareBtn.classList.remove('hidden');
					compareBtn.href = `/buyer/requests/${id}/compare`;
				}

				list.innerHTML = offers.map(o => `
					<tr class="hover:bg-blue-50/30 transition-colors group">
						<td class="px-6 py-4">
							<div class="flex items-center gap-3">
								<div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-600">
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
								</div>
								<div>
									<p class="font-bold text-slate-900">${o.seller_name}</p>
									<p class="text-xs text-slate-500">${o.seller_company}</p>
								</div>
							</div>
						</td>
						<td class="px-6 py-4 text-slate-500 font-medium">
							${new Date(o.submitted_at).toLocaleDateString('tr-TR')}
							<p class="text-[10px] text-slate-400">${new Date(o.submitted_at).toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' })}</p>
						</td>
						<td class="px-6 py-4">
							<span class="px-2 py-1 rounded-md text-[10px] font-bold ${o.shipping_included ? 'bg-green-100 text-green-700' : 'bg-orange-100 text-orange-700'}">
								${o.shipping_included ? 'DAHİL' : 'HARİÇ'}
							</span>
						</td>
						<td class="px-6 py-4">
							<div class="flex flex-wrap gap-2">
								${o.seller_lat ? '<span class="text-blue-500" title="Konum Mevcut"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></span>' : ''}
								${o.attachments ? o.attachments.map(asset => `
									<a href="${asset.type === 'file' ? 'http://localhost:3001' + asset.url : asset.url}" target="_blank" class="text-slate-400 hover:text-blue-600 transition-colors" title="${asset.name}">
										${asset.type === 'file' ? '📄' : '🔗'}
									</a>
								`).join('') : ''}
							</div>
						</td>
						<td class="px-6 py-4">
							<p class="text-lg font-black text-blue-600">₺${o.total.toLocaleString('tr-TR', { minimumFractionDigits: 2 })}</p>
						</td>
						<td class="px-6 py-4 text-right">
							<a href="/buyer/offers/${o.id}" class="inline-flex items-center gap-1.5 font-bold text-blue-600 hover:text-blue-800 transition-colors">
								Detay Gör
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right"><path d="m9 18 6-6-6-6"/></svg>
							</a>
						</td>
					</tr>
				`).join('');
			} catch (err) { console.error(err); }
		}

		loadOffers();

		document.getElementById('btn-invite').onclick = async () => {
			const email = document.getElementById('invite-email').value;
			if (!email) return alert('Lütfen bir email adresi girin.');

			const btn = document.getElementById('btn-invite');
			btn.disabled = true;
			btn.innerHTML = 'GÖNDERİLİYOR...';

			try {
				const res = await fetch(`http://localhost:3001/api/buyer/requests/${id}/invite`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					credentials: 'include',
					body: JSON.stringify({ email })
				});

				if (res.ok) {
					alert('Davetiye başarıyla gönderildi!');
					document.getElementById('invite-email').value = '';
				} else {
					alert('Davetiye gönderilemedi.');
				}
			} catch (err) {
				alert('Bi hata oluştu.');
			} finally {
				btn.disabled = false;
				btn.innerHTML = 'Davet Et';
			}
		};

		const questionsList = document.getElementById('questions-list');
		const answerModal = document.getElementById('answer-modal');
		const currentQuestionText = document.getElementById('modal-question-text');
		const answerText = document.getElementById('answer-text');
		const submitAnswerBtn = document.getElementById('submit-answer');
		let currentQuestionId = null;

		async function loadQuestions() {
			try {
				const res = await fetch(`http://localhost:3001/api/requests/${id}/questions`, { credentials: 'include' });
				const questions = await res.json();

				if (questions.length === 0) {
					questionsList.innerHTML = '<p class="text-center text-slate-400 py-10 font-bold border-2 border-dashed border-slate-100 rounded-3xl">Henüz soru sorulmamış.</p>';
					return;
				}

				questionsList.innerHTML = questions.map(q => {
					// Extract item description from properties if available
					let itemDesc = '';
					if (q.item_properties) {
						const props = q.item_properties;
						itemDesc = props['açıklama'] || props['tanım'] || props['is'] || props['urun'] || 'İsimsiz Ürün';
					}

					return `
					<div class="glass-card p-6 rounded-3xl ${q.answer ? 'border-green-100 bg-green-50/20' : 'border-purple-100 shadow-xl shadow-purple-500/5'}">
						<div class="flex items-start justify-between gap-4">
							<div class="flex-1">
								<div class="flex flex-wrap items-center gap-2 mb-2">
									<span class="text-[10px] font-black text-purple-600 uppercase tracking-widest">${q.seller_company || 'Bilinmeyen Satıcı'} sordu</span>
									${q.item_order ? `<span class="bg-purple-100 text-purple-700 text-[9px] font-black px-2 py-0.5 rounded-full uppercase tracking-tighter">KALEM #${q.item_order} - ${itemDesc}</span>` : ''}
									<span class="text-[10px] text-slate-400 uppercase tracking-widest">• ${new Date(q.created_at).toLocaleString('tr-TR')}</span>
								</div>
								<p class="text-slate-900 font-bold leading-tight mb-4">${q.question}</p>
								
								${q.answer ? `
									<div class="pl-4 border-l-4 border-green-500 mt-4 py-1">
										<p class="text-[10px] font-black text-green-600 uppercase tracking-widest mb-1">Yanıtınız</p>
										<p class="text-slate-700 font-medium text-sm leading-relaxed">${q.answer}</p>
									</div>
								` : `
									<button onclick="openAnswerModal(${q.id}, '${q.question.replace(/'/g, "\\'")}')" class="text-[10px] font-black text-white px-4 py-2 bg-purple-600 rounded-full hover:bg-purple-700 transition-all uppercase tracking-widest shadow-lg shadow-purple-600/20">
										Yanıtla
									</button>
								`}
							</div>
						</div>
					</div>
					`;
				}).join('');
			} catch (err) { console.error(err); }
		}

		window.openAnswerModal = (qId, qText) => {
			currentQuestionId = qId;
			currentQuestionText.textContent = qText;
			answerText.value = '';
			answerModal.classList.remove('hidden');
		};

		document.getElementById('close-answer-modal').onclick = () => answerModal.classList.add('hidden');

		submitAnswerBtn.onclick = async () => {
			if (!answerText.value) return;
			submitAnswerBtn.disabled = true;
			try {
				const res = await fetch(`http://localhost:3001/api/questions/${currentQuestionId}/answer`, {
					method: 'PATCH',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ answer: answerText.value }),
					credentials: 'include'
				});
				if (res.ok) {
					answerModal.classList.add('hidden');
					loadQuestions();
				}
			} catch (err) { console.error(err); }
			finally { submitAnswerBtn.disabled = false; }
		};

		loadQuestions();
	</script>
</Layout>
