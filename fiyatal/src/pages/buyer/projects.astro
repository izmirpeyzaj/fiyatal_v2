---
import Layout from '../../layouts/Layout.astro';
import { Folder, Search, Filter, ChevronRight, Calendar, PlusCircle } from 'lucide-astro';
---

<Layout title="Projelerim" role="buyer">
	<div class="max-w-7xl mx-auto px-4 py-8">
		<div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
			<div>
				<h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Projelerim</h1>
				<p class="text-slate-500 font-medium">Yüklediğiniz Excel dosyaları ve aktif projeleriniz</p>
			</div>
			
			<div class="flex gap-4 w-full md:w-auto">
				<a href="/buyer/new-request" class="btn-primary h-11 px-6 flex items-center gap-2">
					<PlusCircle size={18} />
					Yeni Proje / Excel Yükle
				</a>
			</div>
		</div>

		<div id="projects-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
			<!-- Projects will load here -->
		</div>
	</div>

	<script is:inline>
		const API_BASE = 'http://localhost:3001';
		async function loadProjects() {
			try {
				const res = await fetch(`${API_BASE}/api/buyer/projects`, { credentials: 'include' });
				const projects = await res.json();
				renderProjects(projects);
			} catch (err) { console.error(err); }
		}

		function renderProjects(projects) {
			const container = document.getElementById('projects-grid');
			if(projects.length === 0) {
				container.innerHTML = `
					<div class="col-span-full py-20 text-center">
						<p class="text-slate-400 font-medium italic">Henüz bir projeniz bulunmuyor.</p>
					</div>
				`;
				return;
			}

			container.innerHTML = projects.map(p => `
				<div class="glass-card p-6 rounded-3xl hover:shadow-2xl transition-all group">
					<div class="flex items-start justify-between mb-4">
						<div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-colors">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-folder"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/></svg>
						</div>
					</div>
					
					<h3 class="text-lg font-black text-slate-900 mb-2 line-clamp-1">${p.name}</h3>
					
					<div class="space-y-3 mb-6">
						<div class="flex items-center gap-2 text-sm text-slate-400 font-medium">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/></svg>
							${new Date(p.created_at).toLocaleDateString('tr-TR')}
						</div>
					</div>

					<div class="flex items-center justify-between pt-4 border-t border-slate-50">
						<span class="text-xs font-bold text-slate-400 uppercase tracking-widest">${p.request_count} Talep</span>
						<a href="/buyer/dashboard" class="text-blue-600 font-bold text-sm flex items-center gap-1 hover:gap-2 transition-all">
							Taleplerimi Gör <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right"><path d="m9 18 6-6-6-6"/></svg>
						</a>
					</div>
				</div>
			`).join('');
		}

		loadProjects();
	</script>
</Layout>
