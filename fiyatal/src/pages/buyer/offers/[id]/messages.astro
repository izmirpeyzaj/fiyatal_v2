---
import Layout from '../../../../layouts/Layout.astro';
import { Send, ArrowLeft, MessageSquare, User } from 'lucide-astro';
---

<Layout title="Mesajlar" role="buyer">
	<div class="max-w-3xl mx-auto px-4 py-6 flex flex-col h-[calc(100vh-4rem)]">
		<div class="glass-card rounded-3xl flex flex-col flex-grow overflow-hidden">
			<div class="flex items-center gap-4 p-5 border-b border-slate-100">
				<a href="javascript:history.back()" class="flex items-center justify-center w-10 h-10 rounded-xl bg-slate-100 text-slate-500 hover:bg-blue-100 hover:text-blue-600 transition-all">
					<ArrowLeft size={20} />
				</a>
				<div class="flex items-center gap-3 flex-grow">
					<div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-600">
						<MessageSquare size={20} />
					</div>
					<div>
						<h1 id="chat-title" class="text-lg font-black text-slate-900">Teklif Mesajlari</h1>
						<p id="chat-subtitle" class="text-xs text-slate-500 font-medium"></p>
					</div>
				</div>
			</div>

			<div id="messages-container" class="flex-grow overflow-y-auto p-5 space-y-4">
				<div class="flex flex-col items-center justify-center h-full text-center py-20">
					<div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mb-4">
						<MessageSquare size={32} class="text-slate-300" />
					</div>
					<p class="text-slate-400 font-bold">Mesajlar yukleniyor...</p>
				</div>
			</div>

			<div class="p-4 border-t border-slate-100 bg-white/50">
				<div class="flex items-center gap-3">
					<input
						type="text"
						id="message-input"
						class="input-field flex-grow h-12 rounded-xl"
						placeholder="Mesajinizi yazin..."
					/>
					<button
						id="send-btn"
						class="btn-primary h-12 w-12 flex items-center justify-center rounded-xl shrink-0"
					>
						<Send size={20} />
					</button>
				</div>
			</div>
		</div>
	</div>

	<script is:inline>
		const API_BASE = 'http://localhost:3001';
		const offerId = window.location.pathname.split('/')[4];
		let currentUserId = null;
		let refreshInterval = null;

		const messagesContainer = document.getElementById('messages-container');
		const messageInput = document.getElementById('message-input');
		const sendBtn = document.getElementById('send-btn');

		async function loadProfile() {
			try {
				const res = await fetch(API_BASE + '/api/users/profile', { credentials: 'include' });
				const data = await res.json();
				currentUserId = data.id;
			} catch (err) {
				console.error(err);
			}
		}

		async function loadOfferInfo() {
			try {
				const res = await fetch(API_BASE + '/api/buyer/offers/' + offerId, { credentials: 'include' });
				const offer = await res.json();
				document.getElementById('chat-title').textContent = 'Teklif #' + offer.id + ' - Mesajlar';
				document.getElementById('chat-subtitle').textContent = offer.seller_company + ' ile gorusme';
			} catch (err) {
				console.error(err);
			}
		}

		async function loadMessages() {
			try {
				const res = await fetch(API_BASE + '/api/messages/' + offerId, { credentials: 'include' });
				const messages = await res.json();
				renderMessages(messages);
			} catch (err) {
				console.error(err);
			}
		}

		function renderMessages(messages) {
			if (!messages || messages.length === 0) {
				messagesContainer.innerHTML =
					'<div class="flex flex-col items-center justify-center h-full text-center py-20">' +
						'<div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mb-4">' +
							'<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>' +
						'</div>' +
						'<p class="text-slate-400 font-bold text-lg">Henuz mesaj yok</p>' +
						'<p class="text-slate-400 text-sm mt-1">Satici ile iletisime gecmek icin bir mesaj gonderin.</p>' +
					'</div>';
				return;
			}

			messagesContainer.innerHTML = messages.map(function(msg) {
				var isSent = msg.sender_id === currentUserId;
				var bubbleClass = isSent ? 'sent' : 'received';
				var alignClass = isSent ? 'items-end' : 'items-start';
				var time = new Date(msg.created_at).toLocaleString('tr-TR', {
					day: '2-digit',
					month: '2-digit',
					year: 'numeric',
					hour: '2-digit',
					minute: '2-digit'
				});

				return '<div class="flex flex-col ' + alignClass + '">' +
					'<div class="flex items-center gap-2 mb-1 ' + (isSent ? 'flex-row-reverse' : '') + '">' +
						'<div class="w-6 h-6 rounded-full flex items-center justify-center text-white text-[10px] font-bold ' + (isSent ? 'bg-blue-600' : 'bg-slate-400') + '">' +
							'<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>' +
						'</div>' +
						'<span class="text-[10px] font-bold text-slate-500">' + window.escapeHtml(msg.sender_name || 'Bilinmeyen') + '</span>' +
						'<span class="text-[10px] text-slate-400">' + window.escapeHtml(msg.sender_company || '') + '</span>' +
					'</div>' +
					'<div class="message-bubble ' + bubbleClass + '">' +
						'<p class="text-sm font-medium leading-relaxed">' + window.escapeHtml(msg.message) + '</p>' +
					'</div>' +
					'<span class="text-[9px] text-slate-400 mt-1 px-1">' + window.escapeHtml(time) + '</span>' +
				'</div>';
			}).join('');

			messagesContainer.scrollTop = messagesContainer.scrollHeight;
		}

		async function sendMessage() {
			var text = messageInput.value.trim();
			if (!text) return;

			sendBtn.disabled = true;
			messageInput.disabled = true;

			try {
				var res = await fetch(API_BASE + '/api/messages/' + offerId, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					credentials: 'include',
					body: JSON.stringify({ message: text })
				});

				if (res.ok) {
					messageInput.value = '';
					await loadMessages();
				}
			} catch (err) {
				console.error(err);
			} finally {
				sendBtn.disabled = false;
				messageInput.disabled = false;
				messageInput.focus();
			}
		}

		sendBtn.onclick = sendMessage;

		messageInput.addEventListener('keydown', function(e) {
			if (e.key === 'Enter' && !e.shiftKey) {
				e.preventDefault();
				sendMessage();
			}
		});

		async function init() {
			await loadProfile();
			await loadOfferInfo();
			await loadMessages();
			refreshInterval = setInterval(loadMessages, 5000);
		}

		init();
	</script>
</Layout>
