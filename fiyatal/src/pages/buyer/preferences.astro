---
import Layout from '../../layouts/Layout.astro';
import { Bell, Mail, Smartphone, Save, Check } from 'lucide-astro';
---

<Layout title="Bildirim Tercihleri" role="buyer">
	<div class="max-w-3xl mx-auto px-4 py-8 pb-32">
		<div class="mb-8">
			<h1 class="text-3xl font-extrabold text-slate-900 tracking-tight flex items-center gap-3">
				<div class="p-2 bg-blue-50 text-blue-600 rounded-xl">
					<Bell size={28} />
				</div>
				Bildirim Tercihleri
			</h1>
			<p class="text-slate-500 font-medium mt-2">Hangi bildirimleri almak istediginizi buradan yonetebilirsiniz</p>
		</div>

		<div class="space-y-6">
			<div class="glass-card p-8 rounded-3xl">
				<div class="flex items-center gap-3 mb-8 pb-4 border-b border-slate-100">
					<div class="p-2 bg-blue-50 text-blue-600 rounded-lg">
						<Mail size={24} />
					</div>
					<h2 class="text-xl font-bold text-slate-900">E-posta Bildirimleri</h2>
				</div>

				<div class="space-y-5">
					<label class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100 cursor-pointer hover:bg-slate-100 transition-colors">
						<div>
							<p class="text-sm font-bold text-slate-900">Yeni Teklif</p>
							<p class="text-xs text-slate-500 mt-0.5">Taleplerinize yeni bir teklif geldiginde bildirim alin</p>
						</div>
						<div class="relative">
							<input type="checkbox" id="email_new_offer" class="peer sr-only" />
							<div class="w-11 h-6 bg-slate-300 rounded-full peer-checked:bg-blue-600 transition-colors"></div>
							<div class="absolute left-0.5 top-0.5 w-5 h-5 bg-white rounded-full shadow-sm peer-checked:translate-x-5 transition-transform"></div>
						</div>
					</label>

					<label class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100 cursor-pointer hover:bg-slate-100 transition-colors">
						<div>
							<p class="text-sm font-bold text-slate-900">Yeni Talep</p>
							<p class="text-xs text-slate-500 mt-0.5">Yeni bir talep olusturuldugundan haberdar olun</p>
						</div>
						<div class="relative">
							<input type="checkbox" id="email_new_request" class="peer sr-only" />
							<div class="w-11 h-6 bg-slate-300 rounded-full peer-checked:bg-blue-600 transition-colors"></div>
							<div class="absolute left-0.5 top-0.5 w-5 h-5 bg-white rounded-full shadow-sm peer-checked:translate-x-5 transition-transform"></div>
						</div>
					</label>

					<label class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100 cursor-pointer hover:bg-slate-100 transition-colors">
						<div>
							<p class="text-sm font-bold text-slate-900">Teknik Soru</p>
							<p class="text-xs text-slate-500 mt-0.5">Teknik bir soru soruldugunda e-posta ile bilgilendirilin</p>
						</div>
						<div class="relative">
							<input type="checkbox" id="email_question" class="peer sr-only" />
							<div class="w-11 h-6 bg-slate-300 rounded-full peer-checked:bg-blue-600 transition-colors"></div>
							<div class="absolute left-0.5 top-0.5 w-5 h-5 bg-white rounded-full shadow-sm peer-checked:translate-x-5 transition-transform"></div>
						</div>
					</label>

					<label class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100 cursor-pointer hover:bg-slate-100 transition-colors">
						<div>
							<p class="text-sm font-bold text-slate-900">Durum Degisikligi</p>
							<p class="text-xs text-slate-500 mt-0.5">Talep veya teklif durumu degistiginde bildirim alin</p>
						</div>
						<div class="relative">
							<input type="checkbox" id="email_status_change" class="peer sr-only" />
							<div class="w-11 h-6 bg-slate-300 rounded-full peer-checked:bg-blue-600 transition-colors"></div>
							<div class="absolute left-0.5 top-0.5 w-5 h-5 bg-white rounded-full shadow-sm peer-checked:translate-x-5 transition-transform"></div>
						</div>
					</label>

					<label class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100 cursor-pointer hover:bg-slate-100 transition-colors">
						<div>
							<p class="text-sm font-bold text-slate-900">Gunluk Ozet</p>
							<p class="text-xs text-slate-500 mt-0.5">Her gun taleplerinizin ozetini e-posta olarak alin</p>
						</div>
						<div class="relative">
							<input type="checkbox" id="email_daily_summary" class="peer sr-only" />
							<div class="w-11 h-6 bg-slate-300 rounded-full peer-checked:bg-blue-600 transition-colors"></div>
							<div class="absolute left-0.5 top-0.5 w-5 h-5 bg-white rounded-full shadow-sm peer-checked:translate-x-5 transition-transform"></div>
						</div>
					</label>
				</div>
			</div>

			<div class="glass-card p-8 rounded-3xl">
				<div class="flex items-center gap-3 mb-8 pb-4 border-b border-slate-100">
					<div class="p-2 bg-blue-50 text-blue-600 rounded-lg">
						<Smartphone size={24} />
					</div>
					<h2 class="text-xl font-bold text-slate-900">Uygulama Bildirimleri</h2>
				</div>

				<div class="space-y-5">
					<label class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100 cursor-pointer hover:bg-slate-100 transition-colors">
						<div>
							<p class="text-sm font-bold text-slate-900">Yeni Teklif</p>
							<p class="text-xs text-slate-500 mt-0.5">Uygulama icinde yeni teklif bildirimi alin</p>
						</div>
						<div class="relative">
							<input type="checkbox" id="app_new_offer" class="peer sr-only" />
							<div class="w-11 h-6 bg-slate-300 rounded-full peer-checked:bg-blue-600 transition-colors"></div>
							<div class="absolute left-0.5 top-0.5 w-5 h-5 bg-white rounded-full shadow-sm peer-checked:translate-x-5 transition-transform"></div>
						</div>
					</label>

					<label class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100 cursor-pointer hover:bg-slate-100 transition-colors">
						<div>
							<p class="text-sm font-bold text-slate-900">Yeni Talep</p>
							<p class="text-xs text-slate-500 mt-0.5">Uygulama icinde yeni talep bildirimi alin</p>
						</div>
						<div class="relative">
							<input type="checkbox" id="app_new_request" class="peer sr-only" />
							<div class="w-11 h-6 bg-slate-300 rounded-full peer-checked:bg-blue-600 transition-colors"></div>
							<div class="absolute left-0.5 top-0.5 w-5 h-5 bg-white rounded-full shadow-sm peer-checked:translate-x-5 transition-transform"></div>
						</div>
					</label>

					<label class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100 cursor-pointer hover:bg-slate-100 transition-colors">
						<div>
							<p class="text-sm font-bold text-slate-900">Teknik Soru</p>
							<p class="text-xs text-slate-500 mt-0.5">Teknik sorular icin uygulama bildirimi alin</p>
						</div>
						<div class="relative">
							<input type="checkbox" id="app_question" class="peer sr-only" />
							<div class="w-11 h-6 bg-slate-300 rounded-full peer-checked:bg-blue-600 transition-colors"></div>
							<div class="absolute left-0.5 top-0.5 w-5 h-5 bg-white rounded-full shadow-sm peer-checked:translate-x-5 transition-transform"></div>
						</div>
					</label>

					<label class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100 cursor-pointer hover:bg-slate-100 transition-colors">
						<div>
							<p class="text-sm font-bold text-slate-900">Durum Degisikligi</p>
							<p class="text-xs text-slate-500 mt-0.5">Durum degisikliklerinde uygulama bildirimi alin</p>
						</div>
						<div class="relative">
							<input type="checkbox" id="app_status_change" class="peer sr-only" />
							<div class="w-11 h-6 bg-slate-300 rounded-full peer-checked:bg-blue-600 transition-colors"></div>
							<div class="absolute left-0.5 top-0.5 w-5 h-5 bg-white rounded-full shadow-sm peer-checked:translate-x-5 transition-transform"></div>
						</div>
					</label>
				</div>
			</div>

			<div class="flex justify-end">
				<button id="save-btn" class="btn-primary flex items-center gap-2 px-8 py-3 rounded-2xl text-lg font-bold">
					<Save size={20} />
					Tercihleri Kaydet
				</button>
			</div>
		</div>

		<div id="toast" class="fixed bottom-6 right-6 bg-green-600 text-white px-6 py-3 rounded-2xl shadow-2xl flex items-center gap-2 font-bold text-sm translate-y-20 opacity-0 transition-all duration-300 z-50">
			<Check size={18} />
			<span>Tercihleriniz basariyla kaydedildi</span>
		</div>
	</div>

	<script is:inline>
		const API_BASE = 'http://localhost:3001';

		const prefFields = [
			'email_new_offer',
			'email_new_request',
			'email_question',
			'email_status_change',
			'email_daily_summary',
			'app_new_offer',
			'app_new_request',
			'app_question',
			'app_status_change'
		];

		async function loadPreferences() {
			try {
				const res = await fetch(`${API_BASE}/api/users/preferences`, { credentials: 'include' });
				const prefs = await res.json();
				prefFields.forEach(function(field) {
					const el = document.getElementById(field);
					if (el) el.checked = prefs[field] === 1;
				});
			} catch (err) {
				console.error('Tercihler yuklenemedi:', err);
			}
		}

		function showToast() {
			const toast = document.getElementById('toast');
			toast.classList.remove('translate-y-20', 'opacity-0');
			toast.classList.add('translate-y-0', 'opacity-100');
			setTimeout(function() {
				toast.classList.add('translate-y-20', 'opacity-0');
				toast.classList.remove('translate-y-0', 'opacity-100');
			}, 3000);
		}

		document.getElementById('save-btn').onclick = async function() {
			const body = {};
			prefFields.forEach(function(field) {
				const el = document.getElementById(field);
				if (el) body[field] = el.checked;
			});

			try {
				const res = await fetch(`${API_BASE}/api/users/preferences`, {
					method: 'PUT',
					headers: { 'Content-Type': 'application/json' },
					credentials: 'include',
					body: JSON.stringify(body)
				});
				if (res.ok) {
					showToast();
				}
			} catch (err) {
				console.error('Kaydetme hatasi:', err);
			}
		};

		loadPreferences();
	</script>
</Layout>
